// ======================== GPOTB44 — Opportunité ========================
model Opportunite {
  id              String            @id @default(uuid())
  titre           String
  organisme       String
  description     String
  type            TypeOpportunite   @default(SUBVENTION)
  secteur         String
  paysId          String?
  pays            Pays?             @relation(fields: [paysId], references: [id])
  montant         String?
  dateLimite      DateTime?
  lienSource      String?
  statut          StatutOpportunite @default(BROUILLON)
  datePublication DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("GPOTB44")
}
