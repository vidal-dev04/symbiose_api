# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/symbiose_pays?schema=public"

# JWT
JWT_SECRET="CHANGE_ME_super_secret_key_32chars"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="CHANGE_ME_refresh_secret_key_32chars"
JWT_REFRESH_EXPIRES_IN="7d"

# Brevo (email - optionnel, utiliser Gmail si non configuré)
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@symbiosepays.com"
BREVO_SENDER_NAME="Symbiose Pays"

# Gmail SMTP (prioritaire sur Brevo)
EMAIL_USER="votre.email@gmail.com"
EMAIL_PASS="votre_app_password_16_chars"

# GROQ IA - Analyse des dossiers d'inscription
# Créer une clé sur https://console.groq.com
GROQ_API_KEY=""

# Frontend URL (pour les liens dans les emails)
FRONTEND_URL="http://localhost:4200"

# Tarif mensuel en FCFA
TARIF_MENSUEL=16500

# Essai gratuit (jours) pour les organisations
ESSAI_JOURS=3
